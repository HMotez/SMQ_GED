# =============================================================
# SMQ_GED — Environment Variables Template  (ACTIA ES)
# =============================================================
# Utilisé par docker-compose pour :
#   1. Interpolation ${VAR} dans docker-compose.yml
#   2. Injection de variables dans le container backend
#
# Pour démarrer :
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)
#   → puis remplir les valeurs ci-dessous
#
# IMPORTANT : Ne jamais committer le fichier .env dans Git.
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB
# in the docker-compose postgres service.
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=smq_db
DB_PORT=5432

# DB_HOST is OVERRIDDEN by docker-compose to "postgres" (service name).
# Keep this value for local development without Docker.
DB_HOST=localhost

# ── Express API ───────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── JWT Authentication ────────────────────────────────────────
# Use a long, random secret in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=8h

# ── File Storage ──────────────────────────────────────────────
# Absolute path INSIDE the container (do not change for Docker).
# For local dev without Docker, use: ../storage
UPLOAD_DIR=/app/storage

# ── LibreOffice ───────────────────────────────────────────────
# Path INSIDE the container (Debian apt install libreoffice).
# For local Windows dev, use: C:\Program Files\LibreOffice\program\soffice.exe
SOFFICE_PATH=/usr/bin/soffice

# ── Gemini AI API (Sprint 6 — Chatbot IA) ────────────────────
# Obtenir une clé gratuite sur https://aistudio.google.com
# Le chatbot fonctionne en mode NLP local sans cette clé.
# Avec la clé, les réponses sont générées par Gemini 2.0 Flash.
GEMINI_API_KEY=your_gemini_api_key_here
