# =============================================================
# SMQ_GED — Environment Variables Template  (ACTIA ES)
# Sprint 26 — Reset mot de passe par email
# =============================================================
# Pour démarrer :
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)
#   → puis remplir les valeurs ci-dessous
#
# IMPORTANT : Ne jamais committer le fichier .env dans Git.
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB
# in the docker-compose postgres service.
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=smq_db
DB_PORT=5432

# DB_HOST is OVERRIDDEN by docker-compose to "postgres" (service name).
# Keep this value for local development without Docker.
DB_HOST=localhost

# ── Express API ───────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── JWT Authentication ────────────────────────────────────────
# Use a long, random secret in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=8h

# ── File Storage ──────────────────────────────────────────────
# Absolute path INSIDE the container (do not change for Docker).
# For local dev without Docker, use: ../storage
UPLOAD_DIR=/app/storage

# Host path mounted into the backend container as /app/storage
# Windows : STORAGE_PATH=/app/storage
# Ubuntu  : STORAGE_PATH=/home/<user>/actia_storage   (or leave empty for default)
STORAGE_PATH=/app/storage

# ── LibreOffice ───────────────────────────────────────────────
# Path INSIDE the container (Debian apt install libreoffice).
# For local Windows dev, use: C:\Program Files\LibreOffice\program\soffice.exe
SOFFICE_PATH=/usr/bin/soffice

# ── Application URL ───────────────────────────────────────────
# URL publique de l'application (utilisée dans les liens des emails de reset).
# En production Docker : http://localhost ou votre domaine (ex: https://ged.actia.com)
# En développement local : http://localhost:5173
APP_URL=http://localhost

# ── SMTP — Envoi d'emails (reset mdp, notifications) ─────────
# Fournisseur recommandé : Gmail (activer "Mots de passe d'application")
# Autres : Outlook, SendGrid, Mailtrap (tests)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=SMQ GED ACTIA <your.email@gmail.com>

# Email admin — reçoit toujours une copie des notifications critiques
ADMIN_NOTIFY_EMAIL=admin@actia.com

# ── Groq AI API (Sprint 12 — Chatbot IA streaming) ───────────
# Obtenir une clé gratuite sur https://console.groq.com
# Le chatbot fonctionne en mode NLP local sans cette clé.
# Avec la clé, les réponses sont streamées par llama-3.3-70b.
GROQ_API_KEY=your_groq_api_key_here
