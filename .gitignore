# Environment variables — NEVER commit
.env
.env.local
.env.*.local
.env.staging
backend/.env
backend/tests/.env.test

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/build/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Database backups — contain DB data, never commit
backups/*.sql.gz
backups/*.sql

# SSL private keys — never commit
*.key
db/certs/server.key
frontend/certs/server.key

# IDE
.vscode/
.idea/

# Reports
reports/security/*.txt
reports/security/*.json

# OS generated
*.DS_Store
Thumbs.db
