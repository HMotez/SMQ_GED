# ============================================================
# Security Test Configuration — copy this file to .env.test
# Then fill in the values matching your backend/.env
# ============================================================

# Backend API (direct, no nginx)
TEST_API_URL=http://localhost:4000

# Nginx HTTP (for redirect tests) — requires Docker running
TEST_NGINX_URL=http://localhost:80

# Nginx HTTPS (for SSL/WAF tests) — requires Docker running
TEST_NGINX_HTTPS_URL=https://localhost:443

# ── Admin account (from backend/.env ADMIN_EMAIL / ADMIN_PASSWORD) ──
TEST_ADMIN_EMAIL=admin@actia.ged
TEST_ADMIN_PASSWORD=Admin@ACTIA2025!

# ── Ing. Qualité account (from backend/.env ING_EMAIL / ING_PASSWORD) ──
TEST_USER_EMAIL=ing@actia.ged
TEST_USER_PASSWORD=IngQ@ACTIA2025!

# ── Reviewer account (lowest privilege) ──
TEST_REVIEWER_EMAIL=reviewer@actia.ged
TEST_REVIEWER_PASSWORD=Reviewer@ACTIA2025!

# ── Lockable test account — USED FOR BRUTE FORCE TEST ONLY ──
# This account WILL be locked (15 min) during test 01.
# Use the Reviewer account or create a dedicated test user.
# RESET AFTER TEST (run in psql):
#   UPDATE users SET login_attempts=0, locked_until=NULL WHERE email='reviewer@actia.ged';
TEST_LOCKABLE_EMAIL=reviewer@actia.ged
TEST_LOCKABLE_PASSWORD=Reviewer@ACTIA2025!
