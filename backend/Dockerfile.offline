# =============================================================
# SMQ_GED — Backend Dockerfile.offline
# Sprint 11 — OpenAI integration (offline rebuild)
#
# Pour reconstruire SANS connexion à Docker Hub.
# Utilise smq_ged-backend:latest (déjà présente localement)
# comme base — contient Node 20 + LibreOffice.
#
# IMPORTANT Sprint 11: le paquet "openai" a été ajouté.
# Ce fichier réinstalle les dépendances production si package.json
# a changé, puis écrase le code source.
#
# Usage :
#   docker build -f Dockerfile.offline -t smq_ged-backend:latest .
# Ou via docker-compose :
#   docker-compose -f docker-compose.yml -f docker-compose.offline.yml up --build
# =============================================================

# ── Base locale (aucun pull Docker Hub requis) ────────────────
FROM smq_ged-backend:latest

WORKDIR /app

# Copier package.json pour détecter les changements de dépendances
# (openai a été ajouté en Sprint 11 — réinstallation nécessaire)
COPY package*.json ./

# Réinstaller les dépendances production si package.json a changé
RUN npm ci --omit=dev

# Remplacer le code source
COPY src/ ./src/

EXPOSE 4000
ENV NODE_ENV=production

CMD ["node", "src/server.js"]
